\@writefile{toc}{\contentsline {subsection}{\numberline {5.1}Venter Diagnostics with Real GDELT Data}{7}{subsection.5.1}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {1}{\ignorespaces Venter dual-criterion diagnostics (real GDELT data, 30 training scenarios). Chain-ladder is applicable only when CV $< 0.30$ AND intercept is non-significant ($|a| < 2\cdot $SE($a$)). ``BF'' = Bornhuetter-Ferguson fallback.\relax }}{7}{table.caption.3}\protected@file@percent }
\newlabel{tab:venter}{{1}{7}{Venter dual-criterion diagnostics (real GDELT data, 30 training scenarios). Chain-ladder is applicable only when CV $< 0.30$ AND intercept is non-significant ($|a| < 2\cdot $SE($a$)). ``BF'' = Bornhuetter-Ferguson fallback.\relax }{table.caption.3}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Venter regression scatter plots for all four SREDT level transitions (30 training scenarios, real GDELT data). Each panel plots $C(i,j)$ vs.\nobreakspace  {}$C(i,j+1)$ with the OLS regression line and 95\% confidence band. The L1$\to $L2 panel (top right) shows the only chain-ladder-valid transition: low scatter around the regression line (CV=0.274, $R^2=0.841$, non-significant intercept). The L2$\to $L3 and L3$\to $L4 panels exhibit high scatter (CV=0.715 and 0.661), indicating BF fallback.\relax }}{8}{figure.caption.4}\protected@file@percent }
\newlabel{fig:fig3}{{3}{8}{Venter regression scatter plots for all four SREDT level transitions (30 training scenarios, real GDELT data). Each panel plots $C(i,j)$ vs.~$C(i,j+1)$ with the OLS regression line and 95\% confidence band. The L1$\to $L2 panel (top right) shows the only chain-ladder-valid transition: low scatter around the regression line (CV=0.274, $R^2=0.841$, non-significant intercept). The L2$\to $L3 and L3$\to $L4 panels exhibit high scatter (CV=0.715 and 0.661), indicating BF fallback.\relax }{figure.caption.4}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {5.2}Reclassification of Original Experiment Results}{8}{subsection.5.2}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Projected SREDT scores and flat cosine scores for all 10 test scenarios, sorted by SREDT score. The one materialized scenario (ING Group, reputational risk, marked with $\star $) received the lowest SREDT score (0.181) due to synthetic-fallback articles deflating its observed levels. Flat cosine more closely tracks actual article relevance for the materialized scenario.\relax }}{9}{figure.caption.6}\protected@file@percent }
\newlabel{fig:fig4}{{4}{9}{Projected SREDT scores and flat cosine scores for all 10 test scenarios, sorted by SREDT score. The one materialized scenario (ING Group, reputational risk, marked with $\star $) received the lowest SREDT score (0.181) due to synthetic-fallback articles deflating its observed levels. Flat cosine more closely tracks actual article relevance for the materialized scenario.\relax }{figure.caption.6}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {5.3}Prediction Performance}{9}{subsection.5.3}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {2}{\ignorespaces Test scenario prediction metrics against LLM-judge ground truth (10 test scenarios, 1 materialized). Lower Brier score is better. SREDT underperforms flat cosine on all metrics.\relax }}{9}{table.caption.5}\protected@file@percent }
\newlabel{tab:scores}{{2}{9}{Test scenario prediction metrics against LLM-judge ground truth (10 test scenarios, 1 materialized). Lower Brier score is better. SREDT underperforms flat cosine on all metrics.\relax }{table.caption.5}{}}
