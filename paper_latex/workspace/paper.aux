\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces The Semantic Risk Evidence Development Triangle (SREDT) framework. LLM-generated risk scenarios populate the rows; five ontological abstraction levels (L0--L4) populate the columns. Training scenarios (top rows) have all five levels observed; test scenarios evaluated at day 45 have L3--L4 latent (shaded), creating the triangular missing-data structure. Venter dual-criterion diagnostics select the projection method (chain-ladder, factor-plus-constant, or BF fallback) per transition before projecting latent values.\relax }}{3}{figure.caption.1}\protected@file@percent }
\providecommand*\caption@xref[2]{\@setref\relax\@undefined{#1}}
\newlabel{fig:fig1}{{1}{3}{The Semantic Risk Evidence Development Triangle (SREDT) framework. LLM-generated risk scenarios populate the rows; five ontological abstraction levels (L0--L4) populate the columns. Training scenarios (top rows) have all five levels observed; test scenarios evaluated at day 45 have L3--L4 latent (shaded), creating the triangular missing-data structure. Venter dual-criterion diagnostics select the projection method (chain-ladder, factor-plus-constant, or BF fallback) per transition before projecting latent values.\relax }{figure.caption.1}{}}
